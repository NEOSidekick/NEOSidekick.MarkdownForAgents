prototype(Neos.Neos:Page) {
    httpResponseHead.headers.Link.@process.appendAgentLinks = Neos.Fusion:Join {
        @glue = ', '

        existing = ${value}
        existing.@if.has = ${value}

        markdownAlternate = Neos.Neos:NodeUri {
            @if.notInBackend = ${!documentNode.context.inBackend}
            node = ${documentNode}
            absolute = true
            format = 'markdown'
            @process.wrapAsLinkHeader = ${'<' + value + '>; rel="alternate"; type="text/markdown"'}
        }
        llmsTxt = Neos.Neos:NodeUri {
            @if.notInBackend = ${!documentNode.context.inBackend}
            node = ${site}
            absolute = true
            format = 'txt.llms'
            @process.wrapAsLinkHeader = ${'<' + value + '>; rel="describedby"; type="text/markdown"'}
        }
    }
}
