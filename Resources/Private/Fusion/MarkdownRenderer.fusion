prototype(NEOSidekick.MarkdownForAgents:MarkdownRenderer) {
    @class = 'NEOSidekick\\MarkdownForAgents\\Fusion\\MarkdownRendererImplementation'
    type = null
    suffix = '.Markdown'
    fallbackToHtml = true
    title = ''
    canonicalUri = ''
    formNoticeLabel = ''
    iframeFallbackLabel = ''
}
