include: **/*.fusion

root {
    markdownFormat {
        @position = 'before format'
        condition = ${request.format == 'markdown'}
        type = 'NEOSidekick.MarkdownForAgents:DocumentResponse'
    }
    llmsTxt {
        @position = 'before format'
        condition = ${request.format == 'txt.llms'}
        renderer = NEOSidekick.MarkdownForAgents:LlmsTxt
    }
}
