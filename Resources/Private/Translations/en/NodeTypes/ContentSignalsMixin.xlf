<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
    <file original="" product-name="NEOSidekick.MarkdownForAgents" source-language="en" datatype="plaintext">
        <body>
            <trans-unit id="groups.agentsContentSignals" xml:space="preserve">
                <source>Agents Content Signals</source>
            </trans-unit>
            <trans-unit id="properties.contentSignalAiTrain" xml:space="preserve">
                <source>Allow AI Training</source>
            </trans-unit>
            <trans-unit id="properties.contentSignalAiTrain.ui.help.message" xml:space="preserve">
                <source>Allow crawlers to use site content for training or fine-tuning AI models. Renders ai-train=yes when enabled, ai-train=no when disabled.</source>
            </trans-unit>
            <trans-unit id="properties.contentSignalSearch" xml:space="preserve">
                <source>Allow Search</source>
            </trans-unit>
            <trans-unit id="properties.contentSignalSearch.ui.help.message" xml:space="preserve">
                <source>Allow crawlers to build a search index and provide search results with hyperlinks and short excerpts. Search does not include AI-generated search summaries.</source>
            </trans-unit>
            <trans-unit id="properties.contentSignalAiInput" xml:space="preserve">
                <source>Allow AI Input</source>
            </trans-unit>
            <trans-unit id="properties.contentSignalAiInput.ui.help.message" xml:space="preserve">
                <source>Allow crawlers to input site content into AI models for retrieval augmented generation, grounding, or real-time generative AI search answers.</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxt" xml:space="preserve">
                <source>LLMs.txt content</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxt.ui.help.message" xml:space="preserve">
                <source>Describe here, for AI agents and LLMs, what the website is about: a title, a short summary and the key topics. When left empty, the page title and meta description are used as the LLMs.txt content.</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxtNavigationLevels" xml:space="preserve">
                <source>Navigation depth in LLMs.txt</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxtNavigationLevels.ui.help.message" xml:space="preserve">
                <source>When an option is selected here, the LLMs.txt gets an additional section containing a menu link list at the selected depth.</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxtNavigationLevels.selectBoxEditor.placeholder" xml:space="preserve">
                <source>Do not render navigation</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxtNavigationLevels.selectBoxEditor.values.1" xml:space="preserve">
                <source>1 level</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxtNavigationLevels.selectBoxEditor.values.2" xml:space="preserve">
                <source>2 levels</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxtNavigationLevels.selectBoxEditor.values.3" xml:space="preserve">
                <source>3 levels</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxtNavigationLevels.selectBoxEditor.values.4" xml:space="preserve">
                <source>4 levels</source>
            </trans-unit>
            <trans-unit id="properties.llmsTxtNavigationLevels.selectBoxEditor.values.5" xml:space="preserve">
                <source>5 levels</source>
            </trans-unit>
        </body>
    </file>
</xliff>
